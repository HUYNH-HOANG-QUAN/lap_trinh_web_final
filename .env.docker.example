# =====================================================
# Docker Compose environment file for ProFit
# Copy this file to .env (same directory as docker-compose.yml)
# =====================================================

# ---- Ports exposed on host ----
FRONTEND_PORT=8080
BACKEND_PORT=3001

# ---- Application ----
NODE_ENV=production
PORT=3001

# ---- MySQL (Aiven) ----
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ---- CORS ----
# Cho phép frontend domain nào gọi tới backend (dấu * = tất cả, không khuyến nghị ở production)
CORS_ORIGIN=https://protech-frontend.onrender.com

# ---- Frontend base URL (dùng cho email reset password, v.v.) ----
# Docker: http://localhost:8080 | Render: https://protech-frontend.onrender.com
FRONTEND_BASE_URL=https://protech-frontend.onrender.com

# ---- JWT ----
# Đổi sang chuỗi bí mật dài >= 64 ký tự ở production
JWT_SECRET=
JWT_EXPIRATION_MS=86400000
JWT_REMEMBER_EXPIRATION_MS=604800000

# ---- Bootstrap admin (tạo tài khoản admin mặc định khi container khởi động) ----
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@profit.com
BOOTSTRAP_ADMIN_PHONE=0123456789
BOOTSTRAP_ADMIN_PASSWORD=

# ---- Bootstrap customer ----
BOOTSTRAP_CUSTOMER_ENABLED=true
BOOTSTRAP_CUSTOMER_FULL_NAME=Khach Hang
BOOTSTRAP_CUSTOMER_EMAIL=khachhang@gmail.com
BOOTSTRAP_CUSTOMER_PHONE=0987654321
BOOTSTRAP_CUSTOMER_PASSWORD=

# ---- Gmail SMTP (Đăng ký + Quên mật khẩu) ----
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# ---- Google OAuth 2.0 (Đăng nhập Google) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://protech-frontend.onrender.com/api/v1/auth/google/callback

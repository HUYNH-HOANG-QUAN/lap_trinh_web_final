{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://protech-backend-1qu3.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://protech-backend-1qu3.onrender.com/uploads/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "https://protech-backend-1qu3.onrender.com/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

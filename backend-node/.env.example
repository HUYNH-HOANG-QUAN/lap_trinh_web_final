PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_NAME=ProFitSuppsDB
DB_USER=root
DB_PASSWORD=root

# Gmail SMTP cho chức năng gửi mail (Đăng ký + Quên mật khẩu)
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# Google OAuth 2.0 (đăng nhập Google)
# Tạo tại: Google Cloud Console → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

# Frontend base URL (cho redirect sau khi đăng nhập Google)
# FRONTEND_BASE_URL=http://localhost:8080

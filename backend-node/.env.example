PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ProFitSuppsDB
DB_USER=root
DB_PASSWORD=root

# JWT
JWT_SECRET=ProFitSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLong2024
JWT_EXPIRATION_MS=86400000
JWT_REMEMBER_EXPIRATION_MS=604800000

# VNPay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3001/api/v1/payment/vnpay-return
VNPAY_IPN_URL=http://localhost:3001/api/v1/payment/vnpay-ipn

# Frontend
FRONTEND_BASE_URL=http://localhost:5173

# Bootstrap Admin
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@profit.com
BOOTSTRAP_ADMIN_PHONE=0123456789
BOOTSTRAP_ADMIN_PASSWORD=Admin@123

# Bootstrap Customer
BOOTSTRAP_CUSTOMER_ENABLED=true

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Hộp thư liên hệ — VitaStore Admin</title>
  <link rel="stylesheet" href="/static/admin/css/style.css?v=2" />
</head>
<body>
  <div class="admin-layout">
    <%- include('../fragments/sidebar') %>
    <div class="main-wrap">
      <header class="topbar">
        <div class="topbar-info">
          <div class="topbar-title">Hộp thư liên hệ</div>
          <div class="topbar-breadcrumb">Quản lý tin nhắn từ khách hàng</div>
        </div>
        <div class="topbar-right">
          <button class="icon-btn" onclick="toggleLogoutDropdown()">⚙️</button>
          <div class="dropdown-menu" id="logoutDropdown" style="display:none">
            <button class="dropdown-item dropdown-item-logout" onclick="logout()">❌ Đăng xuất</button>
          </div>
        </div>
      </header>

      <div class="page-wrap">
        <div class="page-header">
          <div>
            <div class="page-title">Hộp thư liên hệ</div>
            <div class="page-subtitle">Tin nhắn liên hệ từ khách hàng</div>
          </div>
          <button class="btn btn-outline" onclick="loadMessages()">🔄 Làm mới</button>
        </div>

        <div class="stats-grid" style="margin-bottom:20px">
          <div class="stat-card"><div class="stat-icon blue">📨</div><div><div class="stat-val" id="countTotal">—</div><div class="stat-label">Tổng tin nhắn</div></div></div>
          <div class="stat-card"><div class="stat-icon orange">📬</div><div><div class="stat-val" id="countUnread">—</div><div class="stat-label">Chưa đọc</div></div></div>
          <div class="stat-card"><div class="stat-icon green">✅</div><div><div class="stat-val" id="countReplied">—</div><div class="stat-label">Đã trả lời</div></div></div>
          <div class="stat-card"><div class="stat-icon cyan">👁</div><div><div class="stat-val" id="countRead">—</div><div class="stat-label">Đã đọc</div></div></div>
        </div>

        <div class="card">
          <div class="card-header">
            <div class="toolbar">
              <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text" id="searchInput" placeholder="Tìm tên, email, chủ đề..." oninput="filterMessages()" />
              </div>
              <select class="select-filter" id="statusFilter" onchange="filterMessages()">
                <option value="">Tất cả trạng thái</option>
                <option value="UNREAD">Chưa đọc</option>
                <option value="READ">Đã đọc</option>
                <option value="REPLIED">Đã trả lời</option>
              </select>
            </div>
            <span class="badge badge-info" id="msgCount">—</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Trạng thái</th>
                  <th>Người gửi</th>
                  <th>Chủ đề</th>
                  <th>Nội dung</th>
                  <th>Ngày gửi</th>
                  <th>Thao tác</th>
                </tr>
              </thead>
              <tbody id="messagesBody"><tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted)">Đang tải...</td></tr></tbody>
            </table>
          </div>
          <div class="pagination-wrap" id="paginationWrap" style="display:none">
            <div class="pagination-info" id="paginationInfo"></div>
            <div class="pagination" id="paginationBtns"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal: Chi tiết + Trả lời -->
  <div class="modal-overlay" id="detailModalOverlay">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="detailTitle">Chi tiết tin nhắn</div>
        <button class="btn btn-ghost btn-icon" onclick="Modal.close('detailModalOverlay')">✕</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="detailId" />
        <div class="form-grid" style="margin-bottom:16px">
          <div class="form-group"><label class="form-label">Người gửi</label><div id="detailSender" style="padding:6px 0;font-weight:600"></div></div>
          <div class="form-group"><label class="form-label">Email</label><div id="detailEmail" style="padding:6px 0;color:var(--primary)"></div></div>
        </div>
        <div class="form-group"><label class="form-label">Chủ đề</label><div id="detailSubject" style="padding:6px 0;font-weight:600"></div></div>
        <div class="form-group"><label class="form-label">Nội dung</label><div id="detailContent" style="padding:10px;background:var(--bg);border-radius:8px;white-space:pre-wrap;line-height:1.6;max-height:200px;overflow-y:auto;border:1px solid var(--border)"></div></div>
        <div class="form-group"><label class="form-label">Ngày gửi</label><div id="detailDate" style="padding:6px 0;color:var(--text-muted);font-size:13px"></div></div>
        <div id="replySection" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
          <div class="form-group"><label class="form-label">📝 Trả lời khách hàng</label>
            <textarea class="form-control" id="replyContent" rows="4" placeholder="Nhập nội dung trả lời..."></textarea>
          </div>
          <div id="existingReply" style="display:none;margin-bottom:16px">
            <label class="form-label">📨 Phản hồi đã gửi</label>
            <div id="existingReplyContent" style="padding:10px;background:#f0fdf4;border-radius:8px;border:1px solid #bbf7d0;white-space:pre-wrap;line-height:1.6;color:#166534;font-size:13px"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="Modal.close('detailModalOverlay')">Đóng</button>
        <button class="btn btn-primary" id="replyBtn" onclick="submitReply()">✉️ Gửi trả lời</button>
      </div>
    </div>
  </div>

  <script src="/static/admin/js/admin.js"></script>
  <script>
    let allMessages = [];
    let currentPage = 1;
    const pageLimit = 20;

    async function loadMessages() {
      try {
        const data = await API.getMessages();
        allMessages = Array.isArray(data) ? data : [];
        renderStats();
        filterMessages();
      } catch(e) {
        console.error('Load messages error:', e);
        document.getElementById('messagesBody').innerHTML =
          `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--red)">Lỗi: ${e.message}</td></tr>`;
      }
    }

    function filterMessages() {
      const search = document.getElementById('searchInput').value.trim().toLowerCase();
      const status = document.getElementById('statusFilter').value;

      let filtered = allMessages.filter(m => {
        if (status && m.status !== status) return false;
        if (search) {
          const hay = (m.userFullName || '').toLowerCase() + ' ' +
                      (m.userEmail || '').toLowerCase() + ' ' +
                      (m.subject || '').toLowerCase();
          if (!hay.includes(search)) return false;
        }
        return true;
      });

      renderMessages(filtered);
    }

    function renderStats() {
      document.getElementById('countTotal').textContent = allMessages.length;
      document.getElementById('countUnread').textContent = allMessages.filter(m => m.status === 'UNREAD').length;
      document.getElementById('countReplied').textContent = allMessages.filter(m => m.status === 'REPLIED').length;
      document.getElementById('countRead').textContent = allMessages.filter(m => m.status === 'READ').length;
    }

    function renderMessages(list) {
      document.getElementById('msgCount').textContent = `${list.length} tin nhắn`;
      if (!list.length) {
        document.getElementById('messagesBody').innerHTML =
          `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted)">Không có tin nhắn nào</td></tr>`;
        return;
      }
      document.getElementById('messagesBody').innerHTML = list.map(m => {
        const statusMap = {
          'UNREAD': ['<span class="badge badge-orange">📬 Chưa đọc</span>'],
          'READ': ['<span class="badge badge-gray">👁 Đã đọc</span>'],
          'REPLIED': ['<span class="badge badge-success">✉️ Đã trả lời</span>'],
        };
        const statusHtml = statusMap[m.status] || [`<span class="badge badge-gray">${m.status}</span>`];
        const contentPreview = (m.content || '').length > 60
          ? (m.content || '').substring(0, 60) + '…'
          : (m.content || '—');
        const dateStr = m.createdAt ? new Date(m.createdAt).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
        return `<tr>
          <td>${statusHtml}</td>
          <td><strong>${m.userFullName || '—'}</strong><br/><small style="color:var(--text-muted)">${m.userEmail || '—'}</small><br/><small style="color:var(--text-muted)">${m.userPhone || ''}</small></td>
          <td style="font-weight:600;max-width:180px;word-break:break-word">${m.subject || '—'}</td>
          <td style="max-width:220px;font-size:13px;color:var(--text-muted);word-break:break-word">${contentPreview}</td>
          <td class="td-mono" style="font-size:12px;white-space:nowrap">${dateStr}</td>
          <td>
            <div class="action-group">
              <button class="btn btn-sm btn-outline" onclick="openDetail(${m.id})">👁 Xem</button>
              ${m.status !== 'REPLIED' ? `<button class="btn btn-sm btn-primary" onclick="openDetail(${m.id})">✉️ Trả lời</button>` : ''}
            </div>
          </td>
        </tr>`;
      }).join('');
    }

    function openDetail(id) {
      const m = allMessages.find(x => x.id === id);
      if (!m) return;

      document.getElementById('detailId').value = id;
      document.getElementById('detailTitle').textContent = m.subject || 'Chi tiết tin nhắn';
      document.getElementById('detailSender').textContent = m.userFullName || '—';
      document.getElementById('detailEmail').textContent = m.userEmail || '—';
      document.getElementById('detailSubject').textContent = m.subject || '—';
      document.getElementById('detailContent').textContent = m.content || '—';
      document.getElementById('detailDate').textContent = m.createdAt ? new Date(m.createdAt).toLocaleString('vi-VN', { dateStyle: 'long', timeStyle: 'short' }) : '—';

      const existingReply = document.getElementById('existingReply');
      const existingContent = document.getElementById('existingReplyContent');
      if (m.replyContent) {
        existingReply.style.display = 'block';
        existingContent.textContent = m.replyContent + (m.repliedAt ? `\n\n(Đã gửi lúc: ${new Date(m.repliedAt).toLocaleString('vi-VN')})` : '');
      } else {
        existingReply.style.display = 'none';
      }

      const replyBtn = document.getElementById('replyBtn');
      if (m.status === 'REPLIED') {
        replyBtn.style.display = 'none';
      } else {
        replyBtn.style.display = '';
        document.getElementById('replyContent').value = '';
      }

      Modal.open('detailModalOverlay');

      // mark as read if unread
      if (m.status === 'UNREAD') {
        API.markRead(id).then(() => {
          m.status = 'READ';
          renderStats();
          filterMessages();
        }).catch(() => {});
      }
    }

    async function submitReply() {
      const id = document.getElementById('detailId').value;
      const content = document.getElementById('replyContent').value.trim();
      if (!content) { Utils.toast('Vui lòng nhập nội dung trả lời!', 'error'); return; }

      const btn = document.getElementById('replyBtn');
      btn.disabled = true; btn.textContent = '⏳...';

      try {
        await API.replyMessage(parseInt(id), content);
        Utils.toast('Đã gửi phản hồi thành công!');
        Modal.close('detailModalOverlay');
        await loadMessages();
      } catch(e) {
        Utils.toast(e.message || 'Có lỗi khi gửi phản hồi', 'error');
        btn.disabled = false; btn.textContent = '✉️ Gửi trả lời';
      }
    }

    setActiveNav('contact');
    document.addEventListener('DOMContentLoaded', loadMessages);
  </script>
</body>
</html>

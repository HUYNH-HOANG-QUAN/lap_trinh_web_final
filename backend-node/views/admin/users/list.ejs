<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Users — VitaStore Admin</title>
  <link rel="stylesheet" href="/static/admin/css/style.css?v=1" />
</head>
<body>
  <div class="admin-layout">
    <%- include('../fragments/sidebar') %>
    <div class="main-wrap">
      <header class="topbar">
        <div class="topbar-info">
          <div class="topbar-title">Users</div>
          <div class="topbar-breadcrumb">Quản lý tài khoản</div>
        </div>
        <div class="topbar-right">
          <button class="icon-btn" onclick="toggleLogoutDropdown()">⚙️</button>
          <div class="dropdown-menu" id="logoutDropdown" style="display:none">
            <button class="dropdown-item dropdown-item-logout" onclick="logout()">❌ Đăng xuất</button>
          </div>
        </div>
      </header>

      <div class="page-wrap">
        <div class="page-header">
          <div>
            <div class="page-title">Quản lý Users</div>
            <div class="page-subtitle">Tất cả tài khoản người dùng và quản trị viên</div>
          </div>
          <button class="btn btn-primary" onclick="openAdd()">+ Thêm người dùng</button>
        </div>

        <div class="stats-grid" style="margin-bottom:20px">
          <div class="stat-card"><div class="stat-icon blue">👥</div><div><div class="stat-val" id="countAll">—</div><div class="stat-label">Tổng tài khoản</div></div></div>
          <div class="stat-card"><div class="stat-icon cyan">👤</div><div><div class="stat-val" id="countUsers">—</div><div class="stat-label">Người dùng</div></div></div>
          <div class="stat-card"><div class="stat-icon orange">👑</div><div><div class="stat-val" id="countAdmins">—</div><div class="stat-label">Quản trị viên</div></div></div>
          <div class="stat-card"><div class="stat-icon green">✓</div><div><div class="stat-val" id="countActive">—</div><div class="stat-label">Đang hoạt động</div></div></div>
        </div>

        <div class="card">
          <div class="card-header">
            <div class="toolbar">
              <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text" id="searchInput" placeholder="Tìm tên, email, số điện thoại..." oninput="filterUsers()" />
              </div>
              <select class="select-filter" id="roleFilter" onchange="filterUsers()">
                <option value="">Tất cả vai trò</option><option value="ADMIN">Admin</option><option value="CUSTOMER">User</option>
              </select>
              <select class="select-filter" id="statusFilter" onchange="filterUsers()">
                <option value="">Tất cả trạng thái</option><option value="ACTIVE">Active</option><option value="INACTIVE">Inactive</option>
              </select>
            </div>
            <span class="badge badge-info" id="userCount">—</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th class="sortable" data-sort="id" onclick="sortBy('id')">ID <span class="sort-icon" id="sort-icon-id"></span></th>
                  <th class="sortable" data-sort="fullName" onclick="sortBy('fullName')">Full Name <span class="sort-icon" id="sort-icon-fullName"></span></th>
                  <th class="sortable" data-sort="email" onclick="sortBy('email')">Email <span class="sort-icon" id="sort-icon-email"></span></th>
                  <th>Phone</th>
                  <th class="sortable" data-sort="role" onclick="sortBy('role')">Role <span class="sort-icon" id="sort-icon-role"></span></th>
                  <th class="sortable" data-sort="status" onclick="sortBy('status')">Status <span class="sort-icon" id="sort-icon-status"></span></th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="usersBody"><tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">Đang tải...</td></tr></tbody>
            </table>
          </div>
          <div class="pagination-wrap" id="paginationWrap" style="display:none">
            <div class="pagination-info" id="paginationInfo"></div>
            <div class="pagination" id="paginationBtns"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="userModalOverlay">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="userModalTitle">Thêm người dùng</div>
        <button class="btn btn-ghost btn-icon" onclick="Modal.close('userModalOverlay')">✕</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="uId" />
        <div class="form-group"><label class="form-label">Họ và tên *</label><input class="form-control" id="uName" required /></div>
        <div class="form-group"><label class="form-label">Email *</label><input class="form-control" id="uEmail" type="email" required /></div>
        <div class="form-grid">
          <div class="form-group"><label class="form-label">Số điện thoại</label><input class="form-control" id="uPhone" /></div>
          <div class="form-group"><label class="form-label">Vai trò</label><select class="form-control" id="uRole"><option value="CUSTOMER">👤 User</option><option value="ADMIN">👑 Admin</option></select></div>
        </div>
        <div class="form-group"><label class="form-label">Trạng thái</label><select class="form-control" id="uStatus"><option value="ACTIVE">● Active</option><option value="INACTIVE">● Inactive</option></select></div>
        <div class="form-group" id="passwordField"><label class="form-label">Mật khẩu</label><input class="form-control" id="uPassword" type="password" /></div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="Modal.close('userModalOverlay')">Hủy</button>
        <button class="btn btn-primary" id="uSaveBtn" onclick="saveUser()">💾 Lưu</button>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="deleteModalOverlay">
    <div class="modal modal-sm">
      <div class="modal-body" style="padding:32px 28px 20px;text-align:center">
        <div class="confirm-icon">🗑️</div><div class="confirm-title">Xác nhận xóa tài khoản</div>
        <div class="confirm-text">Bạn đang xóa tài khoản<br /><strong id="deleteTargetLabel"></strong></div>
        <div class="countdown-bar"><div class="countdown-fill" id="countdownFill"></div></div>
        <div class="countdown-label" id="countdownLabel">Vui lòng chờ 10 giây...</div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="DeleteConfirm.hide()">Hủy</button>
        <button class="btn btn-danger" id="confirmDeleteBtn" onclick="DeleteConfirm.confirm()" disabled>Xác nhận xóa</button>
      </div>
    </div>
  </div>

  <script src="/static/admin/js/admin.js"></script>
  <script>
    let currentPage = 1;
    const pageLimit = 20;
    let currentSort = { sortBy: 'createdAt', sortDir: 'DESC' };

    async function loadUsers() {
      try {
        const search = document.getElementById("searchInput").value.trim();
        const role = document.getElementById("roleFilter").value;
        const status = document.getElementById("statusFilter").value;
        const params = {
          page: currentPage, limit: pageLimit,
          sortBy: currentSort.sortBy, sortDir: currentSort.sortDir,
        };
        if (search) params.search = search;
        if (role) params.role = role;
        if (status) params.status = status;

        const res = await API.getUsers(params);
        const users = Array.isArray(res) ? res : (res.data || []);
        const total = res.total || users.length;
        const totalPages = res.totalPages || Math.ceil(total / pageLimit);

        document.getElementById("countAll").textContent = res.total || 0;
        document.getElementById("countUsers").textContent = users.filter(u => u.role === "CUSTOMER").length;
        document.getElementById("countAdmins").textContent = users.filter(u => u.role === "ADMIN").length;
        document.getElementById("countActive").textContent = users.filter(u => u.status === "ACTIVE").length;

        renderUsers(users);
        renderPagination(res.total || users.length, totalPages);
      } catch(e) { console.error(e); }
    }

    function renderUsers(list) {
      document.getElementById("userCount").textContent = `${list.length} tài khoản`;
      document.getElementById("usersBody").innerHTML = list.length
        ? list.map(u => `<tr><td class="td-mono">${u.id}</td><td><strong>${u.fullName}</strong></td><td>${u.email}</td><td class="td-mono">${u.phone || '—'}</td><td>${Utils.roleBadge(u.role)}</td><td>${Utils.userStatusBadge(u.status)}</td><td><div class="action-group"><button class="btn btn-sm btn-outline" onclick='openEdit(${JSON.stringify(u)})'>✏️ Edit</button><button class="btn btn-sm btn-danger" onclick="confirmDelete(${u.id},'${u.fullName.replace(/'/g, "\\'")}')">🗑</button></div></td></tr>`).join("")
        : `<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">Không tìm thấy</td></tr>`;
    }

    function renderPagination(total, totalPages) {
      if (totalPages <= 1) { document.getElementById("paginationWrap").style.display = "none"; return; }
      document.getElementById("paginationWrap").style.display = "flex";
      document.getElementById("paginationInfo").textContent = `Trang ${currentPage} / ${totalPages} — ${total} tài khoản`;
      const btns = document.getElementById("paginationBtns");
      let html = '';
      if (currentPage > 1) html += `<button class="btn btn-sm btn-outline" onclick="goPage(${currentPage - 1})">←</button>`;
      const maxBtns = 5;
      let start = Math.max(1, currentPage - Math.floor(maxBtns / 2));
      let end = Math.min(totalPages, start + maxBtns - 1);
      if (end - start < maxBtns - 1) start = Math.max(1, end - maxBtns + 1);
      if (start > 1) { html += `<button class="btn btn-sm btn-ghost" onclick="goPage(1)">1</button>`; if (start > 2) html += `<span style="padding:0 4px;color:var(--text-muted)">...</span>`; }
      for (let i = start; i <= end; i++) html += `<button class="btn btn-sm ${i === currentPage ? 'btn-primary' : 'btn-ghost'}" onclick="goPage(${i})">${i}</button>`;
      if (end < totalPages) { if (end < totalPages - 1) html += `<span style="padding:0 4px;color:var(--text-muted)">...</span>`; html += `<button class="btn btn-sm btn-ghost" onclick="goPage(${totalPages})">${totalPages}</button>`; }
      if (currentPage < totalPages) html += `<button class="btn btn-sm btn-outline" onclick="goPage(${currentPage + 1})">→</button>`;
      btns.innerHTML = html;
    }

    function goPage(p) { currentPage = p; loadUsers(); }
    function filterUsers() { currentPage = 1; loadUsers(); }

    function sortBy(field) {
      if (currentSort.sortBy === field) currentSort.sortDir = currentSort.sortDir === 'ASC' ? 'DESC' : 'ASC';
      else { currentSort.sortBy = field; currentSort.sortDir = 'ASC'; }
      updateSortIcons();
      currentPage = 1;
      loadUsers();
    }

    function updateSortIcons() {
      document.querySelectorAll('.sort-icon').forEach(el => el.textContent = '');
      const icon = document.getElementById(`sort-icon-${currentSort.sortBy}`);
      if (icon) icon.textContent = currentSort.sortDir === 'ASC' ? '↑' : '↓';
    }

    function openAdd() {
      editUserId = null;
      document.getElementById("userModalTitle").textContent = "Thêm người dùng mới";
      ["uId","uName","uEmail","uPhone","uPassword"].forEach(id => document.getElementById(id).value = "");
      document.getElementById("uRole").value = "CUSTOMER";
      document.getElementById("uStatus").value = "ACTIVE";
      Modal.open("userModalOverlay");
    }

    function openEdit(u) {
      editUserId = u.id;
      document.getElementById("userModalTitle").textContent = "Chỉnh sửa người dùng";
      document.getElementById("uId").value = u.id;
      document.getElementById("uName").value = u.fullName;
      document.getElementById("uEmail").value = u.email;
      document.getElementById("uPhone").value = u.phone || "";
      document.getElementById("uRole").value = u.role;
      document.getElementById("uStatus").value = u.status;
      document.getElementById("uPassword").value = "";
      Modal.open("userModalOverlay");
    }

    async function saveUser() {
      const name = document.getElementById("uName").value.trim();
      const email = document.getElementById("uEmail").value.trim();
      const password = document.getElementById("uPassword").value.trim();
      if (!name || !email) { Utils.toast("Vui lòng điền tên và email!", "error"); return; }
      if (!editUserId && !password) { Utils.toast("Vui lòng nhập mật khẩu khi tạo user mới!", "error"); return; }

      const btn = document.getElementById("uSaveBtn");
      btn.disabled = true; btn.textContent = "⏳...";

      const data = {
        fullName: name, email,
        phone: document.getElementById("uPhone").value.trim(),
        role: document.getElementById("uRole").value,
        status: document.getElementById("uStatus").value,
        passwordHash: password,
      };

      try {
        if (editUserId) { await API.updateUser(editUserId, data); Utils.toast("Đã cập nhật tài khoản!"); }
        else { await API.createUser(data); Utils.toast("Đã thêm người dùng mới!"); }
        await loadUsers();
        Modal.close("userModalOverlay");
      } catch (error) {
        Utils.toast(error.message || "Có lỗi khi lưu người dùng", "error");
      } finally {
        btn.disabled = false; btn.innerHTML = "💾 Lưu";
      }
    }

    function confirmDelete(id, name) {
      DeleteConfirm.show(`"${name}"`, async () => {
        try { await API.deleteUser(id); await loadUsers(); Utils.toast(`Đã xóa tài khoản "${name}"`); }
        catch (error) { Utils.toast(error.message || "Có lỗi khi xóa người dùng", "error"); }
      });
    }

    setActiveNav("users");
    document.addEventListener("DOMContentLoaded", () => { loadUsers(); updateSortIcons(); });
  </script>
</body>
</html>

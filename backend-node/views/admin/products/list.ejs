<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Products — VitaStore Admin</title>
  <link rel="stylesheet" href="/static/admin/css/style.css?v=1" />
</head>
<body>
  <div class="admin-layout">
    <%- include('../fragments/sidebar') %>
    <div class="main-wrap">
      <header class="topbar">
        <div class="topbar-info">
          <div class="topbar-title">Products</div>
          <div class="topbar-breadcrumb">Quản lý sản phẩm</div>
        </div>
        <div class="topbar-right">
          <button class="icon-btn" onclick="toggleLogoutDropdown()">⚙️</button>
          <div class="dropdown-menu" id="logoutDropdown" style="display:none">
            <button class="dropdown-item dropdown-item-logout" onclick="logout()">❌ Đăng xuất</button>
          </div>
        </div>
      </header>

      <div class="page-wrap">
        <div class="page-header">
          <div>
            <div class="page-title">Danh sách Products</div>
            <div class="page-subtitle">Quản lý thực phẩm chức năng</div>
          </div>
          <a href="/admin/product/add" class="btn btn-primary">+ Add Product</a>
        </div>

        <div class="card">
          <div class="card-header">
            <div class="toolbar">
              <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text" id="searchInput" placeholder="Tìm tên sản phẩm..." oninput="filterProducts()" />
              </div>
              <select class="select-filter" id="catFilter" onchange="filterProducts()">
                <option value="">Tất cả danh mục</option>
              </select>
              <select class="select-filter" id="stockFilter" onchange="filterProducts()">
                <option value="">Tất cả tồn kho</option>
                <option value="low">Sắp hết (&lt;50)</option>
                <option value="ok">Còn hàng</option>
              </select>
            </div>
            <span class="badge badge-info" id="productCount">—</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th class="sortable" data-sort="id" onclick="sortBy('id')">ID <span class="sort-icon" id="sort-icon-id"></span></th>
                  <th class="sortable" data-sort="categoryId" onclick="sortBy('categoryId')">Category <span class="sort-icon" id="sort-icon-categoryId"></span></th>
                  <th class="sortable" data-sort="name" onclick="sortBy('name')">Name <span class="sort-icon" id="sort-icon-name"></span></th>
                  <th class="sortable" data-sort="price" onclick="sortBy('price')">Price <span class="sort-icon" id="sort-icon-price"></span></th>
                  <th class="sortable" data-sort="ratingAvg" onclick="sortBy('ratingAvg')">Rating <span class="sort-icon" id="sort-icon-ratingAvg"></span></th>
                  <th class="sortable" data-sort="stockQuantity" onclick="sortBy('stockQuantity')">Stock <span class="sort-icon" id="sort-icon-stockQuantity"></span></th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="productsBody"><tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">Đang tải...</td></tr></tbody>
            </table>
          </div>
          <div class="pagination-wrap" id="paginationWrap" style="display:none">
            <div class="pagination-info" id="paginationInfo"></div>
            <div class="pagination" id="paginationBtns"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="deleteModalOverlay">
    <div class="modal modal-sm">
      <div class="modal-body" style="padding:32px 28px 20px;text-align:center">
        <div class="confirm-icon">🗑️</div><div class="confirm-title">Xác nhận xóa sản phẩm</div>
        <div class="confirm-text">Bạn đang xóa sản phẩm<br /><strong id="deleteTargetLabel"></strong><br />Hành động này không thể hoàn tác!</div>
        <div class="countdown-bar"><div class="countdown-fill" id="countdownFill"></div></div>
        <div class="countdown-label" id="countdownLabel">Vui lòng chờ 10 giây...</div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="DeleteConfirm.hide()">Hủy</button>
        <button class="btn btn-danger" id="confirmDeleteBtn" onclick="DeleteConfirm.confirm()" disabled>Xác nhận xóa</button>
      </div>
    </div>
  </div>

  <script src="/static/admin/js/admin.js"></script>
  <script>
    let currentPage = 1;
    const pageLimit = 20;
    let currentSort = { sortBy: 'createdAt', sortDir: 'DESC' };

    async function loadProducts() {
      try {
        const search = document.getElementById("searchInput").value.trim();
        const cat = document.getElementById("catFilter").value;
        const stk = document.getElementById("stockFilter").value;
        const params = {
          page: currentPage, limit: pageLimit,
          sortBy: currentSort.sortBy, sortDir: currentSort.sortDir,
        };
        if (search) params.search = search;
        if (cat) params.categoryId = cat;
        if (stk) params.stockFilter = stk;

        const [products, cats] = await Promise.all([
          API.getProducts(params),
          API.getCategories()
        ]);
        const total = products.total || products.data?.length || 0;
        const totalPages = products.totalPages || Math.ceil(total / pageLimit);
        const list = Array.isArray(products) ? products : (products.data || []);

        // Populate category filter once
        const catSel = document.getElementById("catFilter");
        if (catSel.options.length <= 1) {
          cats.forEach(c => {
            const opt = document.createElement("option");
            opt.value = c.id;
            opt.textContent = c.name;
            catSel.appendChild(opt);
          });
          if (cat) catSel.value = cat;
        }

        renderProducts(list);
        renderPagination(total, totalPages);
      } catch(e) { console.error(e); }
    }

    function renderProducts(list) {
      document.getElementById("productCount").textContent = `${list.length} sản phẩm`;
      document.getElementById("productsBody").innerHTML = list.length
        ? list.map(p => `<tr>
          <td class="td-mono">${p.id}</td>
          <td class="td-mono">${p.categoryId || '—'}</td>
          <td><strong>${p.name}</strong></td>
          <td style="font-weight:700;color:var(--primary)">${Utils.formatCurrency(p.price)}</td>
          <td>${Utils.stars(p.ratingAvg)}</td>
          <td>${p.stockQuantity < 50 ? `<span class="badge badge-warning">⚠ ${p.stockQuantity}</span>` : `<span class="badge badge-success">${p.stockQuantity}</span>`}</td>
          <td><div class="action-group"><a href="/admin/product/add?edit=${p.id}" class="btn btn-sm btn-outline">✏️ Edit</a><button class="btn btn-sm btn-danger" onclick="confirmDelete(${p.id},'${p.name.replace(/'/g, "\\'")}')">🗑 Delete</button></div></td>
        </tr>`).join("")
        : `<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">Không tìm thấy sản phẩm</td></tr>`;
    }

    function renderPagination(total, totalPages) {
      if (totalPages <= 1) { document.getElementById("paginationWrap").style.display = "none"; return; }
      document.getElementById("paginationWrap").style.display = "flex";
      document.getElementById("paginationInfo").textContent = `Trang ${currentPage} / ${totalPages} — ${total} sản phẩm`;
      const btns = document.getElementById("paginationBtns");
      let html = '';
      if (currentPage > 1) html += `<button class="btn btn-sm btn-outline" onclick="goPage(${currentPage - 1})">←</button>`;
      const maxBtns = 5;
      let start = Math.max(1, currentPage - Math.floor(maxBtns / 2));
      let end = Math.min(totalPages, start + maxBtns - 1);
      if (end - start < maxBtns - 1) start = Math.max(1, end - maxBtns + 1);
      if (start > 1) { html += `<button class="btn btn-sm btn-ghost" onclick="goPage(1)">1</button>`; if (start > 2) html += `<span style="padding:0 4px;color:var(--text-muted)">...</span>`; }
      for (let i = start; i <= end; i++) html += `<button class="btn btn-sm ${i === currentPage ? 'btn-primary' : 'btn-ghost'}" onclick="goPage(${i})">${i}</button>`;
      if (end < totalPages) { if (end < totalPages - 1) html += `<span style="padding:0 4px;color:var(--text-muted)">...</span>`; html += `<button class="btn btn-sm btn-ghost" onclick="goPage(${totalPages})">${totalPages}</button>`; }
      if (currentPage < totalPages) html += `<button class="btn btn-sm btn-outline" onclick="goPage(${currentPage + 1})">→</button>`;
      btns.innerHTML = html;
    }

    function goPage(p) { currentPage = p; loadProducts(); }
    function filterProducts() { currentPage = 1; loadProducts(); }

    function sortBy(field) {
      if (currentSort.sortBy === field) currentSort.sortDir = currentSort.sortDir === 'ASC' ? 'DESC' : 'ASC';
      else { currentSort.sortBy = field; currentSort.sortDir = 'ASC'; }
      updateSortIcons();
      currentPage = 1;
      loadProducts();
    }

    function updateSortIcons() {
      document.querySelectorAll('.sort-icon').forEach(el => el.textContent = '');
      const icon = document.getElementById(`sort-icon-${currentSort.sortBy}`);
      if (icon) icon.textContent = currentSort.sortDir === 'ASC' ? '↑' : '↓';
    }

    function confirmDelete(id, name) {
      DeleteConfirm.show(`"${name}"`, async () => {
        try { await API.deleteProduct(id); Utils.toast(`Đã xóa sản phẩm "${name}"`); loadProducts(); }
        catch(e) { Utils.toast(e.message, "error"); }
      });
    }

    setActiveNav("products");
    document.addEventListener("DOMContentLoaded", () => { loadProducts(); updateSortIcons(); });
  </script>
</body>
</html>
